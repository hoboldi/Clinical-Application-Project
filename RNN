    "def create_model(\n",
    "    num_classes, \n",
    "    input_shape, \n",
    "    dropout_rate=0.3,  # Reduced dropout for better training efficiency\n",
    "    filters=64, \n",
    "    kernel_size=3, \n",
    "    residual_blocks=2,  # Reduced number of residual blocks\n",
    "    lstm_units=128,  # Reduced LSTM units\n",
    "    learning_rate=3e-4,\n",
    "    use_attention=True\n",
    "):\n",
    "    inputs = Input(shape=input_shape)\n",
    "    \n",
    "    # Initial Convolutional Layer\n",
    "    x = Conv1D(filters=filters, kernel_size=kernel_size, padding='same', kernel_initializer='he_normal')(inputs)\n",
    "    x = BatchNormalization()(x)\n",
    "    x = LeakyReLU(negative_slope=0.1)(x)\n",
    "    x = MaxPooling1D(pool_size=2)(x)\n",
    "    \n",
    "    # Residual Blocks\n",
    "    for _ in range(residual_blocks):\n",
    "        x = residual_block(x, filters, kernel_size, dropout_rate)\n",
    "    \n",
    "    # Transition Layer\n",
    "    filters *= 2\n",
    "    x = Conv1D(filters=filters, kernel_size=kernel_size, padding='same', kernel_initializer='he_normal')(x)\n",
    "    x = BatchNormalization()(x)\n",
    "    x = LeakyReLU(negative_slope=0.1)(x)\n",
    "    x = MaxPooling1D(pool_size=2)(x)\n",
    "    \n",
    "    # Residual Blocks (Second Stage)\n",
    "    for _ in range(residual_blocks):\n",
    "        x = residual_block(x, filters, kernel_size, dropout_rate)\n",
    "    \n",
    "    # Attention Layer (Improved)\n",
    "    if use_attention:\n",
    "        query = Dense(filters, activation='tanh')(x)\n",
    "        attention_probs = Softmax()(query)\n",
    "        x = Multiply()([x, attention_probs])\n",
    "    \n",
    "    # LSTM Layer (Optimized)\n",
    "    x = LSTM(lstm_units, return_sequences=False, dropout=dropout_rate)(x)  # Removed second LSTM\n",
    "\n",
    "    # Fully Connected Layers\n",
    "    x = Dropout(dropout_rate)(x)\n",
    "    x = Dense(256, activation='relu', kernel_initializer='he_normal')(x)  # Reduced FC layer size\n",
    "    x = Dropout(dropout_rate)(x)\n",
    "    \n",
    "    # Output Layer\n",
    "    outputs = Dense(num_classes, activation='softmax')(x)\n",
    "    \n",
    "    # Create and Compile Model\n",
    "    model = Model(inputs=inputs, outputs=outputs)\n",
    "    model.compile(\n",
    "        optimizer=Adam(learning_rate=learning_rate), \n",
    "        loss='sparse_categorical_crossentropy', \n",
    "        metrics=['accuracy']\n",
    "    )\n",
    "    \n",
    "    return model"
   ]
